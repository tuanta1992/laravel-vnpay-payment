# Mã định danh merchant (Terminal Code)
VNPAY_TMN_CODE=

# Secret key để tạo checksum
VNPAY_HASH_SECRET=

# Môi trường: sandbox hoặc production
VNPAY_ENVIRONMENT=sandbox

# URL VNPay sẽ redirect khách hàng về sau khi thanh toán
VNPAY_RETURN_URL="${APP_URL}/vnpay/return"

# URL VNPay gọi để thông báo kết quả giao dịch (IPN)
VNPAY_IPN_URL="${APP_URL}/vnpay/ipn"

# Ngôn ngữ mặc định: vn (Tiếng Việt) hoặc en (English)
VNPAY_LOCALE=vn

# Thời gian hết hạn thanh toán (phút)
VNPAY_EXPIRE_TIME=15

# Bật/tắt logging
VNPAY_LOG_ENABLED=true

# Log channel (stack, single, daily, etc.)
VNPAY_LOG_CHANNEL=stack

# Timeout cho API requests (giây)
VNPAY_TIMEOUT=30